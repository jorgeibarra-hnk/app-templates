# Atlassian Configuration
# Required for Atlassian Jira and Confluence integration

# Your Atlassian API Token
# Get this from: https://id.atlassian.com/manage-profile/security/api-tokens
DATABRICKS_ATLASSIAN_API_KEY=your_api_token_here

# Your Atlassian email address (the account that created the API token)
DATABRICKS_ATLASSIAN_EMAIL=your-email@example.com

# Your Atlassian site URL
# Format: https://your-domain.atlassian.net
DATABRICKS_ATLASSIAN_SITE_URL=https://your-domain.atlassian.net
